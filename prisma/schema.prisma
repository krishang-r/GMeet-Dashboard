generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  image        String?
  passwordHash String? // null for Google-only accounts
  role         Role     @default(USER)
  createdAt    DateTime @default(now())

  accounts        Account[]
  sessions        Session[]
  groupMembers    GroupMember[]
  meetAssignments MeetAssignment[]
}

model Group {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  members         GroupMember[]
  meetAssignments MeetAssignment[]
}

model GroupMember {
  id      String @id @default(cuid())
  userId  String
  groupId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Meet {
  id          String    @id @default(cuid())
  title       String
  description String?
  url         String
  scheduledAt DateTime? // optional; null = instant/recurring meet with no set time
  createdAt   DateTime  @default(now())

  assignments MeetAssignment[]
}

// A meet can be assigned to a specific user OR to a whole group.
model MeetAssignment {
  id      String  @id @default(cuid())
  meetId  String
  userId  String?
  groupId String?

  meet  Meet   @relation(fields: [meetId], references: [id], onDelete: Cascade)
  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([meetId, userId])
  @@unique([meetId, groupId])
}

// ---- Auth.js (NextAuth) adapter models ----

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
