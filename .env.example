# ---------------------------------------------------------------------------
# Copy this file to `.env` (local) and set the same values in Vercel
# Project Settings -> Environment Variables (Production + Preview).
# ---------------------------------------------------------------------------

# Neon / Postgres connection string (use the POOLED connection string from Neon).
# Looks like: postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Auth.js secret. Generate with: openssl rand -base64 32
AUTH_SECRET="IWsQgNX0vd8H7xrarX1kRm8PwjxXID1VLD99wj1bPK8J"


# Public base URL of the app.
# Local: http://localhost:3000   |   Vercel: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth credentials (from Google Cloud Console -> Credentials).
# Authorized redirect URI must be: <NEXTAUTH_URL>/api/auth/callback/google
# Leave blank to disable the "Sign in with Google" button.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Set to "true" to show the "Continue with Google" button on the login page.
NEXT_PUBLIC_GOOGLE_ENABLED="false"

# Comma-separated list of emails that are automatically granted ADMIN on first login.
# This is how you bootstrap the very first admin account. Use YOUR email here.
ADMIN_EMAILS="you@example.com"

# Optional. Shown before "GMeet Dashboard" in the title, header and login page
# (e.g. "Acme GMeet Dashboard"). Leave blank for plain "GMeet Dashboard".
NEXT_PUBLIC_ORGANISATION_NAME=""
